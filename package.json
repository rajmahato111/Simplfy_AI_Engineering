{
  "name": "simplify-ai-engineering",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate:content": "tsx scripts/content-render-qc.ts",
    "validate:frontmatter": "tsx scripts/validate-frontmatter.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reindex": "tsx scripts/rebuild-search-index.ts",
    "ingest:validate": "tsx scripts/ingest-validate.ts",
    "ingest:glossary": "tsx scripts/ingest-glossary.ts",
    "ingest:patterns": "tsx scripts/ingest-patterns.ts",
    "ingest:questions": "tsx scripts/ingest-questions.ts",
    "ingest:frameworks": "tsx scripts/ingest-frameworks.ts",
    "ingest:meta-pages": "tsx scripts/ingest-meta-pages.ts",
    "ingest:whiteboard": "tsx scripts/ingest-whiteboard-exercises.ts",
    "scaffold:mdx": "tsx scripts/scaffold-mdx.ts",
    "scaffold:mdx:catalog": "tsx scripts/generate-mdx-catalog.ts",
    "sanitize:mdx": "tsx scripts/sanitize-mdx.ts",
    "enhance:mdx": "tsx scripts/enhance-mdx-drafts.ts",
    "demote:auto-enhanced": "tsx scripts/demote-auto-enhanced-mdx.ts",
    "audit:content": "tsx scripts/audit-content-quality.ts",
    "sync:mdx-metadata": "tsx scripts/sync-mdx-metadata.ts",
    "ingest:all": "npm run ingest:glossary && npm run ingest:patterns && npm run ingest:questions && npm run ingest:frameworks && npm run ingest:meta-pages && npm run ingest:whiteboard",
    "setup:env": "bash scripts/setup-env.sh"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "next": "^15.5.0",
    "next-auth": "^5.0.0-beta.31",
    "next-mdx-remote": "^6.0.0",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^22.16.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.31.0",
    "eslint-config-next": "^15.5.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3"
  }
