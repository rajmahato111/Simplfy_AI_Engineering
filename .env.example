# Database (Postgres — Neon, Supabase, or local Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/simplify

# Public site URL (used for sitemap, OG tags, auth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth.js — required in production (openssl rand -base64 32)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
NEXT_PUBLIC_GITHUB_AUTH_ENABLED=false

# Stripe — optional; checkout runs in stub mode without price ID
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Anthropic — optional; tutor, grader, mock interviewer, whiteboard critique
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Dev: set PRO_ACCESS=all to bypass mock paywall and grant Pro features locally
PRO_ACCESS=
